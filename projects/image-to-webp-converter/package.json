{
  "name": "image-to-webp-converter",
  "version": "1.0.0",
  "description": "一个纯前端实现的图片格式转换工具，支持多种格式批量转换为 WebP",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:hexo": "vue-tsc && vite build --config vite.config.hexo.ts",
    "preview": "vite preview"
  },
  "keywords": [
    "image-converter",
    "webp",
    "vue3",
    "vite"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "vue": "^3.4.0",
    "heic2any": "^0.0.4",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.0"
  }
}
